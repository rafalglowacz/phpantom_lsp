<?php

class User {
    public function getName(): string { return ''; }
}

/** @param int[] $numbers */
function test(array $numbers): void {
    $result = array_reduce($numbers, function(User $carry, int $item): User {
        return $carry;
    }, new User());
    $result-><>
}