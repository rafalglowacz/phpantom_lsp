// test: @template-implements resolves interface generic parameter
// feature: completion
// Adapted from phpactor generics/class_template_implements1.test
// ignore: @implements generic resolution not yet supported
// expect: boo(
---
<?php

/**
 * @template Y
 */
interface Second {
    /**
     * @return Y
     */
    public function boo();
}

class Baz {
    public function bazMethod(): void {}
}

/**
 * @template-implements Second<Baz>
 */
class Foo implements Second
{
    public function boo()
    {
    }
}

$foo = new Foo();
$foo->boo()-><>