// test: if/else branch assignments produce union type
// feature: completion
// Adapted from phpactor if-statement/else_assign.test
// expect: fooMethod(
// expect: barMethod(
---
<?php

class Foo {
    public function fooMethod(): void {}
}

class Bar {
    public function barMethod(): void {}
}

function test(bool $cond): void {
    if ($cond) {
        $foo = new Foo();
    } else {
        $foo = new Bar();
    }

    $foo-><>
}