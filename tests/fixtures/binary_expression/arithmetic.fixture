// test: arithmetic operators resolve to int|float
// feature: hover
// Adapted from phpactor binary-expression/arithmetic.test
// expect_hover: $add => int|float
// expect_hover: $sub => int|float
// expect_hover: $mul => int|float
// expect_hover: $div => int|float
// expect_hover: $mod => int
// expect_hover: $pow => int|float
---
<?php

function test(): void {
    $add = 1 + 1;
    $sub = 2 - 1;
    $mul = 2 * 2;
    $div = 4 / 2;
    $mod = 4 % 2;
    $pow = 2 ** 3;
    $<>add;
    $sub;
    $mul;
    $div;
    $mod;
    $pow;
}