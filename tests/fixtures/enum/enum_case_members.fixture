// test: enum case members like name property are accessible
// feature: completion
// Adapted from phpactor enum/enum_case.test
// Accessing Foo::FOO-> should show the name property from UnitEnum
// ignore: enum case instance properties (name, value) not shown in -> completion
// expect: name
---
<?php

enum Foo {
    case FOO;
    case BAR;
}

$case = Foo::FOO;
$case-><>